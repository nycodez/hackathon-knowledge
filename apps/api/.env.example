NODE_ENV=development
HOST=0.0.0.0
PORT=3333
CORS_ORIGIN=http://localhost:4200

# Neon serverless PostgreSQL with pgvector. Create a free project and store the
# pooled connection string only in ignored local files and deployment secrets.
DATABASE_URL=postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/neondb?sslmode=verify-full
PGSSLMODE=verify-full
PG_POOL_MAX=5

# Keep the canonical demo dataset synchronized idempotently on API startup.
SEED_ON_BOOT=true

# Optional Bedrock multilingual vectors; secure full-text retrieval works when off.
EMBEDDINGS_ENABLED=false
EMBEDDING_MODEL=cohere.embed-multilingual-v3

# Optional OCR for scanned PDFs and images. Text documents work without it.
ANTHROPIC_API_KEY=
ANTHROPIC_OCR_MODEL=claude-sonnet-4-20250514

# AWS Bedrock LLM. Set credentials only in an ignored local .env or Vercel secrets.
BEDROCK_CONTEXT_MAX_CHARS=12000
LLM_PROVIDER=deterministic
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_LIGHTWEIGHT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_EMBEDDING_MODEL_ID=cohere.embed-english-v3
