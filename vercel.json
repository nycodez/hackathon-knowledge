{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @hackathon/web build",
  "outputDirectory": "dist/web/browser",
  "fluid": true,
  "regions": ["sin1"],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?__path=:path*"
    },
    {
      "source": "/mytasco/:path*",
      "destination": "/api?__mytasco_path=:path*"
    },
    {
      "source": "/((?!api(?:/|$)|mytasco(?:/|$)|assets(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
